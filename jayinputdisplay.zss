	mapset{map: "_jayinput_keydisplay_item7"; value: 0; redirectid: player(teamside),id}
	mapset{map: "_jayinput_keydisplay_item8"; value: 0; redirectid: player(teamside),id}
	mapset{map: "_jayinput_keydisplay_item9"; value: 0; redirectid: player(teamside),id}
	mapset{map: "_jayinput_keydisplay_item10"; value: 0; redirectid: player(teamside),id}
	mapset{map: "_jayinput_keydisplay_item11"; value: 0; redirectid: player(teamside),id}
	mapset{map: "_jayinput_keydisplay_item12"; value: 0; redirectid: player(teamside),id}
	mapset{map: "_jayinput_keydisplay_item13"; value: 0; redirectid: player(teamside),id}
	mapset{map: "_jayinput_keydisplay_item14"; value: 0; redirectid: player(teamside),id}
